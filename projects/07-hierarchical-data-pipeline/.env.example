# Qualabinance API keys — copy this to `.env` at repo root and fill in.
# NEVER commit a real .env file (already in .gitignore).

# FRED — free, get at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# CoinGecko Pro — optional, free tier works for Fear & Greed
COINGECKO_PRO_KEY=

# Binance — needed for live trading (not for historical OHLCV)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bank of Thailand API Portal — free registration
# https://apiportal.bot.or.th/
BOT_API_KEY=

# Quandl / Nasdaq Data Link — free key for WGC gold data
QUANDL_KEY=

# Where to store the DuckDB + Parquet files
QUALABINANCE_DATA_DIR=./data
